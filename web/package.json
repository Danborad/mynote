{
    "name": "mynote-web",
    "private": true,
    "version": "1.0.3",
    "type": "module",
    "scripts": {
        "dev": "bunx --bun vite",
        "build": "bunx --bun vite build",
        "preview": "bunx --bun vite preview",
        "cap:sync": "bunx --bun cap sync",
        "android:open": "bunx --bun cap open android",
        "android:sync": "bun run build && bunx --bun cap sync android",
        "apk:debug": "bun run build && bunx --bun cap sync android && ./android/gradlew -p android assembleDebug",
        "apk:release": "bun run build && bunx --bun cap sync android && ./android/gradlew -p android assembleRelease"
    },
    "dependencies": {
        "@capacitor/android": "^8.1.0",
        "@capacitor/cli": "^8.1.0",
        "@capacitor/core": "^8.1.0",
        "@capacitor/status-bar": "^8.0.1",
        "@tiptap/extension-code-block-lowlight": "^3.20.0",
        "@tiptap/extension-image": "^3.19.0",
        "@tiptap/extension-placeholder": "^3.27.0",
        "@tiptap/extension-task-item": "^3.19.0",
        "@tiptap/extension-task-list": "^3.19.0",
        "@tiptap/extension-underline": "^3.19.0",
        "@tiptap/pm": "^3.19.0",
        "@tiptap/react": "^3.19.0",
        "@tiptap/starter-kit": "^3.19.0",
        "highlight.js": "^11.11.1",
        "html2canvas": "^1.4.1",
        "lowlight": "^3.3.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-easy-crop": "^5.5.6",
        "react-h5-audio-player": "^3.10.1",
        "turndown": "^7.1.3"
    },
    "devDependencies": {
        "@types/react": "^18.2.43",
        "@types/react-dom": "^18.2.17",
        "@vitejs/plugin-react": "^4.2.1",
        "autoprefixer": "^10.4.16",
        "playwright": "^1.58.2",
        "postcss": "^8.4.32",
        "tailwindcss": "^3.4.0",
        "vite": "^5.0.8"
    }
}
